# ─────────────────────────────────────────────────────────────
# IBKR Gateway / TWS Connection
# ─────────────────────────────────────────────────────────────
IB_HOST=127.0.0.1
IB_PORT=4002          # 4002 = IB Gateway (paper); 4001 = live; 7497 = TWS paper; 7496 = TWS live
IB_CLIENT_ID=1
IB_ACCOUNT_ID=DU1234567   # Your IBKR account number

# ─────────────────────────────────────────────────────────────
# Monthly Budget per Ticker (USD)
# ─────────────────────────────────────────────────────────────
MONTHLY_BUDGET_PER_TICKER=100.0

# ─────────────────────────────────────────────────────────────
# Strategy Parameters
# ─────────────────────────────────────────────────────────────
DIP_THRESHOLD=0.95          # 5% below weighted avg price
LIMIT_ORDER_DISCOUNT=0.002  # 0.20% below yesterday's close
COMMISSION_BUFFER=0.998     # Factor to account for commission in share calculation

# ─────────────────────────────────────────────────────────────
# Email / SMTP Notifications
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here    # Gmail App Password (not your login password)
NOTIFY_TO=recipient@example.com
NOTIFY_FROM=your_email@gmail.com

# ─────────────────────────────────────────────────────────────
# File Paths (override if needed)
# ─────────────────────────────────────────────────────────────
INVESTMENTS_CSV_PATH=data/investments.csv
TRACKER_JSON_PATH=data/tracker.json

# ─────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO    # DEBUG | INFO | WARNING | ERROR
